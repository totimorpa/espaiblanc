{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "espaienblanc",
  "compatibility_date": "2026-05-20",
  "assets": {
    "directory": "./public",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "espaiblanc.com",
      "custom_domain": true
    }
  ]
}
